PAGARE_SPLIT_HOST=0.0.0.0
PAGARE_SPLIT_PORT=8006
PAGARE_SPLIT_RELOAD=false
PAGARE_SPLIT_MAX_PDF_MB=150
PAGARE_SPLIT_DEFAULT_DPI=160

# Solo eliminar hojas en blanco (mismo criterio que TwainBridge / fi-7160)
PAGARE_SPLIT_ELIMINAR_BLANCOS=true
PAGARE_SPLIT_CORREGIR_ORIENTACION=false
PAGARE_SPLIT_APLICAR_DESKEW=false
PAGARE_SPLIT_APLICAR_MEJORA_IMAGEN=false

PAGARE_SPLIT_PREPROCESS_ANALYSIS_DPI=96
PAGARE_SPLIT_PREPROCESS_WORKERS=4

# Umbrales idénticos a TwainBridge ScannerApi (BlankPageMean/Deviation/DarkPixel)
PAGARE_SPLIT_BLANK_MEAN_THRESHOLD=230
PAGARE_SPLIT_BLANK_DEVIATION_THRESHOLD=18
PAGARE_SPLIT_BLANK_DARK_PIXEL_THRESHOLD=175
# PDF: re-analizar zona central si la sombra de borde confunde la página completa
PAGARE_SPLIT_BLANK_ANALYSIS_MAX_SIDE=1200
PAGARE_SPLIT_BLANK_CENTER_MARGIN_FRAC=0.12
PAGARE_SPLIT_BLANK_USE_CENTER_FALLBACK=true
